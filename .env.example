# Microsoft Entra ID (Azure AD)
# Obtener en: portal.azure.com → Azure Active Directory → App registrations
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
AZURE_CLIENT_SECRET=              # NUNCA commitear este valor

# Nota: estas variables residen en el .env del MCP fornado-planner-mcp,
# no en este directorio. El script las carga desde:
# C:\Users\usuario\mcp-servers\fornado-planner-mcp\.env

# Grupos M365 donde buscar planes Planner (separados por coma)
# Si se omite, usa GROUP_ID como fallback (hardcodeado en planner_import.py)
# PLANNER_GROUP_IDS=198b4a0a-39c7-4521-a546-6a008e3a254a,d0f1fcf9-08e5-4415-a2f8-2111b569e0ec

# Scopes utilizados por el script (requieren permisos en la App Registration):
# - Tasks.ReadWrite         → crear/modificar tareas en Planner
# - Tasks.ReadWrite.Shared  → acceder a planes compartidos del grupo
# - Group.ReadWrite.All     → crear planes asociados al grupo M365
# - User.Read               → flujo de autenticación MSAL
