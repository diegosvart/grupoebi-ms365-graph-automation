# =============================================================================
# grupoebi-ms365-graph-automation — Variables de Entorno
# =============================================================================
# Copiar este archivo como .env y completar con valores reales.
# NUNCA commitear el archivo .env al repositorio.
# En produccion, usar Azure Key Vault en lugar de este archivo.
# =============================================================================

# -----------------------------------------------------------------------------
# Azure Entra ID — App Registration (OBLIGATORIO)
# -----------------------------------------------------------------------------
# Tenant ID del directorio de Azure AD de la organizacion
AZURE_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client ID de la App Registration creada en Azure Portal
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client Secret generado en Azure Portal > App Registrations > Certificates & secrets
# Rotar cada 90 dias. Formato: cadena alfanumerica con caracteres especiales (~, ., -)
AZURE_CLIENT_SECRET=tu-secreto-de-app-registration-aqui

# -----------------------------------------------------------------------------
# Microsoft 365 — Identificadores de recursos (OBLIGATORIO para operaciones)
# -----------------------------------------------------------------------------
# ID del grupo M365 destino (Teams/Planner). Obtener desde:
# Graph Explorer: GET /groups?$filter=displayName eq 'Nombre del Team'
GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ID del sitio SharePoint asociado al grupo. Obtener desde:
# GET /groups/{GROUP_ID}/sites/root
SHAREPOINT_SITE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# URL del sitio SharePoint (sin slash final)
# Ejemplo: https://tuempresa.sharepoint.com/sites/nombre-sitio
SHAREPOINT_SITE_URL=https://tuempresa.sharepoint.com/sites/nombre-sitio

# -----------------------------------------------------------------------------
# Talana HRIS — Integracion (requerido para flujos de alta/baja de usuarios)
# -----------------------------------------------------------------------------
# API Key de Talana. Obtener desde: Portal Talana > Configuracion > Integraciones > API
TALANA_API_KEY=tu-api-key-de-talana-aqui

# URL base de la API de Talana (sin slash final)
# Produccion: https://api.talana.com/api
TALANA_API_URL=https://api.talana.com/api

# Secreto para validar la firma HMAC de webhooks entrantes de Talana
# Configurar en Talana > Integraciones > Webhooks > Secreto
TALANA_WEBHOOK_SECRET=tu-secreto-webhook-talana-aqui

# -----------------------------------------------------------------------------
# Azure Functions — Wrapper HTTP para usuarios no tecnicos (opcional)
# -----------------------------------------------------------------------------
# URL base de la Azure Function que expone los flujos via HTTP
# Ejemplo: https://grupoebi-automation.azurewebsites.net/api
AZURE_FUNCTION_URL=https://tu-function-app.azurewebsites.net/api

# Function Key para autenticar llamadas a la Azure Function
AZURE_FUNCTION_KEY=tu-function-key-aqui

# -----------------------------------------------------------------------------
# Microsoft Intune — Gestion de dispositivos (opcional, escalamiento futuro)
# -----------------------------------------------------------------------------
# ID de la politica de compliance por defecto para nuevos dispositivos
INTUNE_DEFAULT_COMPLIANCE_POLICY_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# ID del grupo de Intune al que se asignan nuevos colaboradores
INTUNE_DEFAULT_DEVICE_GROUP_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Configuracion de la aplicacion (opcionales)
# -----------------------------------------------------------------------------
# Nivel de logging: DEBUG | INFO | WARNING | ERROR (default: INFO)
LOG_LEVEL=INFO

# Habilitar modo dry-run por defecto (true | false). Util en CI.
# Si es true, los comandos no hacen llamadas reales a la API salvo que se
# pase --no-dry-run explicitamente.
DEFAULT_DRY_RUN=false

# Numero maximo de reintentos en caso de throttling (HTTP 429)
MAX_RETRIES=3

# Directorio de templates CSV (relativo a la raiz del proyecto)
TEMPLATES_DIR=templates

# -----------------------------------------------------------------------------
# Power Automate / Azure Logic Apps (opcional)
# -----------------------------------------------------------------------------
# URL del webhook de Power Automate para notificaciones de nuevos proyectos
POWER_AUTOMATE_WEBHOOK_URL=https://prod-XX.westus.logic.azure.com/workflows/xxxxx/triggers/manual/paths/invoke?api-version=2016-06-01&sp=%2Ftriggers%2Fmanual%2Frun&sv=1.0&sig=XXXXX

# =============================================================================
# NOTAS DE SEGURIDAD
# =============================================================================
# - Este archivo es SOLO una plantilla. Nunca contiene valores reales.
# - El archivo .env (con valores reales) esta excluido por .gitignore.
# - En produccion, almacenar todos los secretos en Azure Key Vault y
#   referenciarlos desde la configuracion de la Azure Function o del runner CI.
# - Rotar AZURE_CLIENT_SECRET cada 90 dias. Ver SECURITY.md para procedimiento.
# =============================================================================
